{
  "functions": {
    "api/optimize.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/edit-image.js": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
